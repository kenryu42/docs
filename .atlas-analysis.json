  "keyFeatures": [
    "PreToolUse hook intercepts commands before execution across all supported agents",
    "Semantic command analysis — understands intent, not just string patterns",
    "Recursive shell wrapper detection up to 5 levels deep",
    "Interpreter one-liner detection (Python, Node, Ruby, Perl)",
    "Worktree mode to relax rules inside linked git worktrees",
    "Strict mode to fail-closed on unparseable commands",
    "Paranoid mode for maximum protection",
    "Custom user and project-level blocking rules via JSON config",
    "Audit logging of all blocked commands with secret redaction",
    "Status line integration showing active protection mode",
    "Doctor command for installation diagnostics",
    "Explain command for step-by-step command trace analysis"
  ],
  "publicApiSurface": [
    "npx cc-safety-net doctor",
    "npx cc-safety-net doctor --json",
    "npx cc-safety-net doctor --skip-update-check",
    "npx cc-safety-net explain <command>",
    "npx cc-safety-net explain --json <command>",
    "npx cc-safety-net explain --cwd <path> <command>",
    "npx cc-safety-net --statusline",
    "npx cc-safety-net --verify-config",
    "npx cc-safety-net --custom-rules-doc",
    "npx cc-safety-net --version",
    "SAFETY_NET_STRICT=1",
    "SAFETY_NET_PARANOID=1",
    "SAFETY_NET_PARANOID_RM=1",
    "SAFETY_NET_PARANOID_INTERPRETERS=1",
    "SAFETY_NET_WORKTREE=1",
    ".safety-net.json (project config)",
    "~/.cc-safety-net/config.json (user config)"
  ]
}
